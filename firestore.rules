rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isCallParticipant(callId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'username', 'displayName']) &&
             data.id is string &&
             data.username is string && data.username.size() <= 30 &&
             data.displayName is string && data.displayName.size() <= 64;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'roomId', 'senderId', 'content', 'type', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.content is string && data.content.size() <= 10000 &&
             data.createdAt == request.time;
    }

    // --- Collection Guards ---

    // 1. Usernames (Unique Registry)
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid && isValidId(username);
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }

    // 2. Users
    match /users/{userId} {
      function isValidUser(data) {
        return data.id == userId && 
               data.displayName is string && data.displayName.size() <= 100 &&
               (data.username == null || (data.username is string && data.username.size() <= 30)) &&
               (data.phoneNumber == null || (data.phoneNumber is string && data.phoneNumber.size() <= 20));
      }

      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'displayName', 'photoURL', 'backgroundPhotoURL', 'bio', 'status', 
                        'isOnline', 'lastSeen', 'phoneNumber', 'isPrivate', 'ghostMode', 
                        'settings', 'blockedUsers', 'friends', 'friendRequests', 'folders',
                        'onboardingComplete', 'updatedAt', 'username',
                        'birthday', 'residence', 'workplace', 'jobTitle', 'maritalStatus', 
                        'graduationYear', 'placeOfBirth'
                      ])
                    ) || 
                    // Special action: Send Friend Request (Self-Append)
                    (isSignedIn() && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['friendRequests']) &&
                     request.auth.uid in incoming().friendRequests);
    }

    // 3. Rooms
    match /rooms/{roomId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.members || resource.data.type == 'channel');
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.admins || request.auth.uid in request.resource.data.members);
      allow update: if isSignedIn() && (
                      // Action: Join Room
                      (request.resource.data.members.size() > resource.data.members.size() && 
                       request.resource.data.members.hasAll(resource.data.members) &&
                       request.auth.uid in request.resource.data.members &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'updatedAt'])) ||
                      // Action: Admin Edit
                      (request.auth.uid in resource.data.admins && request.resource.data.id == resource.data.id)
                    );
      
      // 3.1 Messages (Subcollection)
      match /messages/{messageId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members);
        allow create: if isSignedIn() && 
                      (request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members) &&
                      isValidMessage(incoming());
        allow update: if isSignedIn() && (
                      // Mark as read/delivered
                      (incoming().diff(existing()).affectedKeys().hasOnly(['readBy', 'deliveredBy'])) ||
                      // Edit own message
                      (existing().senderId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'isEdited', 'updatedAt'])) ||
                      // Pin message (Admin or member depending on room settings, defaulting to member for now)
                      (incoming().diff(existing()).affectedKeys().hasOnly(['isPinned'])) ||
                      // Private delete (deletedFor)
                      (incoming().diff(existing()).affectedKeys().hasOnly(['deletedFor']) && request.auth.uid in incoming().deletedFor)
                    );
        allow delete: if isSignedIn() && (existing().senderId == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.admins);
      }
    }

    // 4. Posts
    match /posts/{postId} {
      allow list: if isSignedIn() && (resource.data.isPublic == true || resource.data.authorUid == request.auth.uid);
      allow get: if isSignedIn();
      allow create: if isSignedIn() && incoming().authorUid == request.auth.uid && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (
                      // Like/Unlike
                      (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) && 
                       (incoming().likes.size() == existing().likes.size() + 1 || incoming().likes.size() == existing().likes.size() - 1)) ||
                      // Edit own post
                      (isOwner(existing().authorUid) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mediaURL', 'isPublic']))
                    );
      allow delete: if isOwner(existing().authorUid);
    }

    // 5. Stories
    match /stories/{storyId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && incoming().authorUid == request.auth.uid && incoming().createdAt == request.time;
      allow update: if isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['views']) && request.auth.uid in incoming().views;
      allow delete: if isOwner(existing().authorUid);
    }

    // 6. Notifications
    match /notifications/{notificationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isOwner(existing().userId);
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isOwner(existing().userId);
    }

    // 7. Calls
    match /calls/{callId} {
      allow read: if isSignedIn() && (
        resource.data.callerId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      allow create: if isSignedIn() && incoming().callerId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.callerId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      ) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'endedAt', 'duration']);
      
      // 7.1 PeerSignals (Subcollection for WebRTC)
      match /peerSignals/{signalId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
